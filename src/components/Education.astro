---
const education = [
  {
    institution: 'Universidad de Alicante',
    url: 'https://www.ua.es',
    degree: 'Grado en Ingeniería Multimedia',
    location: 'Alicante, España',
    period: '2021 – 2025',
    highlights: [
      'Programación y Desarrollo de Software',
      'Diseño Gráfico y Multimedia',
      'Sistemas Multimedia y Producción Audiovisual',
      'Gestión de Proyectos y Emprendimiento',
    ],
    current: true,
  },
  {
    institution: 'Colegio Santa Teresa Alicante',
    url: 'https://colegiosantateresaalicante.org',
    degree: 'Bachillerato Tecnológico',
    location: 'Alicante, España',
    period: '2019 – 2021',
    highlights: [
      'Hábitos de estudio avanzados',
      'Habilidades de comunicación',
      'Pensamiento crítico',
    ],
    current: false,
  },
];
---

<section id="educacion" class="py-24 bg-white reveal-section">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Section header -->
    <div class="flex items-center gap-4 mb-14">
      <span class="text-teal-600 font-mono text-sm font-medium">05.</span>
      <h2 class="text-2xl font-bold text-slate-900">Educación</h2>
      <div class="flex-1 h-px bg-slate-200 max-w-xs"></div>
    </div>

    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-6 top-0 bottom-0 w-px bg-slate-200 hidden md:block"></div>

      <div class="space-y-8">
        {education.map(edu => (
          <div class="md:pl-16 relative">
            <!-- Timeline dot -->
            <div class="absolute left-4 top-6 w-5 h-5 rounded-full border-2 border-teal-400 bg-white hidden md:flex items-center justify-center -translate-x-1/2">
              <div class={`w-2 h-2 rounded-full ${edu.current ? 'bg-teal-400' : 'bg-slate-300'}`}></div>
            </div>

            <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-7 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-1">
                <a
                  href={edu.url}
                  target="_blank"
                  rel="noopener"
                  class="text-xl font-bold text-slate-900 hover:text-teal-600 transition-colors"
                >
                  {edu.institution}
                </a>
                <div class="flex items-center gap-2 flex-shrink-0">
                  {edu.current && (
                    <span class="px-2 py-0.5 text-xs font-semibold bg-teal-50 text-teal-600 border border-teal-100 rounded-full">
                      Actual
                    </span>
                  )}
                  <span class="text-sm text-slate-500">{edu.period}</span>
                </div>
              </div>

              <p class="text-teal-600 font-medium text-sm mb-1">{edu.degree}</p>
              <p class="text-slate-400 text-xs mb-4">{edu.location}</p>

              <div>
                <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-2">Conocimientos relevantes</p>
                <div class="flex flex-wrap gap-2">
                  {edu.highlights.map(h => (
                    <span class="px-3 py-1 text-xs bg-slate-50 text-slate-600 border border-slate-200 rounded-full">
                      {h}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
