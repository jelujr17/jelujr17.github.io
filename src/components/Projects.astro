---
const projects = [
  {
    title: 'Página oficial JaqueMate',
    description: 'Página oficial de Jaquemate con diseño responsivo y único para empresa de ventas al por mayor.',
    image: '/img/fotoWeb.png',
    tech: ['PHP', 'CSS', 'Bootstrap', 'JavaScript'],
    live: 'https://jaquemate.es/',
    featured: true,
  },
  {
    title: 'FamSync',
    description: 'Aplicación móvil para la organización familiar. Diseño adaptable a dispositivos móviles y escritorio con experiencia de usuario optimizada.',
    image: '/img/famsync.png',
    tech: ['Flutter', 'Firebase', 'Dart'],
    live: 'https://www.youtube.com/watch?v=h8I9bihaDTA',
    docs: '/resume/FamSyncMemoria.pdf',
    featured: true,
  },
  {
    title: 'Curse of the Pharaoh',
    description: 'Videojuego indie de terror y puzzles. Motor de juego con interfaces limpias, menús intuitivos y mecánicas bien balanceadas.',
    image: '/img/game.png',
    tech: ['Unity', 'C#'],
    live: 'https://youtu.be/SYIZhXRdxSA',
  },
  {
    title: 'APIRest',
    description: 'API REST para la gestión de datos con endpoints organizados y seguros. Estructura lógica fácil de mantener y escalar.',
    image: '/img/gan.jpg',
    tech: ['Node.js', 'MySQL'],
    github: 'https://github.com/jelujr17/Api_FamSync',
  },
];
---

<section id="proyectos" class="py-24 bg-white reveal-section">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Section header -->
    <div class="flex items-center gap-4 mb-14">
      <span class="text-teal-600 font-mono text-sm font-medium">03.</span>
      <h2 class="text-2xl font-bold text-slate-900">Proyectos</h2>
      <div class="flex-1 h-px bg-slate-200 max-w-xs"></div>
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
      {projects.map(project => (
        <div class="group bg-white border border-slate-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col">

          <!-- Image -->
          <div class="relative h-48 overflow-hidden bg-slate-100">
            <img
              src={project.image}
              alt={project.title}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          </div>

          <!-- Content -->
          <div class="p-6 flex flex-col flex-1">
            <h3 class="text-lg font-bold text-slate-900 mb-2 group-hover:text-teal-600 transition-colors">
              {project.title}
            </h3>
            <p class="text-slate-500 text-sm leading-relaxed flex-1 mb-4">
              {project.description}
            </p>

            <!-- Tech tags -->
            <div class="flex flex-wrap gap-1.5 mb-5">
              {project.tech.map(t => (
                <span class="px-2.5 py-0.5 text-xs font-mono font-medium bg-slate-50 text-slate-600 border border-slate-200 rounded-full">
                  {t}
                </span>
              ))}
            </div>

            <!-- Links -->
            <div class="flex items-center gap-3 mt-auto pt-4 border-t border-slate-100">
              {project.github && (
                <a href={project.github} target="_blank" rel="noopener"
                  class="flex items-center gap-1.5 text-slate-500 hover:text-slate-900 text-sm font-medium transition-colors">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
                  </svg>
                  GitHub
                </a>
              )}
              {project.docs && (
                <a href={project.docs} target="_blank" rel="noopener"
                  class="flex items-center gap-1.5 text-slate-500 hover:text-slate-900 text-sm font-medium transition-colors">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                  </svg>
                  Docs
                </a>
              )}
              {project.live && (
                <a href={project.live} target="_blank" rel="noopener"
                  class="ml-auto flex items-center gap-1.5 text-teal-600 hover:text-teal-700 text-sm font-semibold transition-colors">
                  Ver proyecto
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
