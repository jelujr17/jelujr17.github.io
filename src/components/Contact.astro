---

<section id="contacto" class="py-24 reveal-section" style="background: linear-gradient(135deg, #0f172a 0%, #0d3b36 55%, #134e4a 100%);">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Section header -->
    <div class="flex items-center gap-4 mb-6">
      <span class="text-teal-400 font-mono text-sm font-medium">06.</span>
      <h2 class="text-2xl font-bold text-white">Contacto</h2>
      <div class="flex-1 h-px bg-slate-700 max-w-xs"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-12 items-center">

      <!-- Left: message -->
      <div class="space-y-5">
        <h3 class="text-4xl font-extrabold text-white leading-tight">
          ¿Hablamos?
        </h3>
        <p class="text-slate-400 leading-relaxed">
          Estoy disponible para nuevas oportunidades, colaboraciones o simplemente para hablar sobre tecnología.
          No dudes en escribirme.
        </p>
        <a
          href="mailto:marioml7902@gmail.com"
          class="inline-flex items-center gap-2 px-6 py-3 bg-teal-600 hover:bg-teal-500 text-white font-semibold rounded-xl transition-all shadow-lg shadow-teal-900/40 hover:shadow-teal-700/40 text-sm"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          Enviar email
        </a>
      </div>

      <!-- Right: links -->
      <div class="space-y-3">
        {socials.map(s => (
          <a
            href={s.href}
            target={s.href.startsWith('http') ? '_blank' : undefined}
            rel={s.href.startsWith('http') ? 'noopener' : undefined}
            class="flex items-center gap-4 p-4 rounded-xl border border-slate-700 bg-slate-800/40 hover:border-teal-500/50 hover:bg-slate-800/70 transition-all group"
          >
            <span class="text-teal-400 group-hover:text-teal-300 transition-colors flex-shrink-0" set:html={s.icon} />
            <div class="min-w-0">
              <p class="text-xs font-medium text-slate-500 uppercase tracking-widest">{s.label}</p>
              <p class="text-slate-300 group-hover:text-white transition-colors text-sm font-medium truncate">{s.value}</p>
            </div>
            <svg class="ml-auto w-4 h-4 text-slate-600 group-hover:text-teal-400 transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        ))}
      </div>
    </div>

  </div>
</section>

<!-- Footer -->
<footer class="py-6 bg-slate-950 border-t border-slate-800">
  <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm text-slate-600">
    <span>© {new Date().getFullYear()} Mario Martínez</span>
    <span>Hecho con <a href="https://astro.build" target="_blank" class="text-teal-600 hover:text-teal-400 transition-colors">Astro</a> + <a href="https://tailwindcss.com" target="_blank" class="text-teal-600 hover:text-teal-400 transition-colors">Tailwind</a></span>
  </div>
</footer>
