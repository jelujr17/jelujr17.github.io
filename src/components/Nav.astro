---
const links = [
  { href: '#sobre-mi', label: 'Sobre mí' },
  { href: '#experiencia', label: 'Experiencia' },
  { href: '#proyectos', label: 'Proyectos' },
  { href: '#skills', label: 'Skills' },
  { href: '#educacion', label: 'Educación' },
  { href: '#contacto', label: 'Contacto' },
];
---

<header
  id="nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="#hero" class="text-white font-bold text-lg tracking-tight hover:text-teal-400 transition-colors">
      Mario Martínez
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8">
      {links.map(link => (
        <a
          href={link.href}
          class="text-sm font-medium text-slate-300 hover:text-teal-400 transition-colors relative group"
        >
          {link.label}
          <span class="absolute -bottom-0.5 left-0 w-0 h-0.5 bg-teal-400 transition-all duration-200 group-hover:w-full"></span>
        </a>
      ))}
      <a
        href="/resume/CV.pdf"
        target="_blank"
        class="text-sm font-semibold px-4 py-2 border border-teal-400 text-teal-400 rounded-lg hover:bg-teal-400 hover:text-slate-900 transition-all duration-200"
      >
        CV
      </a>
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="menu-btn"
      class="md:hidden text-white p-1"
      aria-label="Abrir menú"
    >
      <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-slate-900/95 backdrop-blur-sm border-t border-slate-800">
    <nav class="flex flex-col px-6 py-4 gap-1">
      {links.map(link => (
        <a
          href={link.href}
          class="mobile-link text-slate-300 hover:text-teal-400 py-3 text-sm font-medium border-b border-slate-800 last:border-0 transition-colors"
        >
          {link.label}
        </a>
      ))}
      <a
        href="/resume/CV.pdf"
        target="_blank"
        class="mobile-link mt-3 text-center py-2.5 border border-teal-400 text-teal-400 rounded-lg text-sm font-semibold hover:bg-teal-400 hover:text-slate-900 transition-all"
      >
        Descargar CV
      </a>
    </nav>
  </div>
</header>

<script>
  // Nav scroll effect: transparent → dark on scroll
  const nav = document.getElementById('nav')!;
  const onScroll = () => {
    if (window.scrollY > 60) {
      nav.classList.add('bg-slate-900/95', 'backdrop-blur-sm', 'shadow-lg', 'shadow-black/20');
      nav.classList.remove('py-4');
      nav.querySelector('.max-w-6xl')!.classList.add('py-3');
    } else {
      nav.classList.remove('bg-slate-900/95', 'backdrop-blur-sm', 'shadow-lg', 'shadow-black/20');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });

  // Mobile menu toggle
  const btn = document.getElementById('menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  btn.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    iconOpen.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
  });

  // Close mobile menu on link click
  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
    });
  });
</script>
